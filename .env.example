# CodeCourt MVP — Root Environment Variables
# Copy this file to .env and fill in your actual values
# Note: Each service (backend, ai-service, frontend) has its own .env.example

# =============================================================================
# GLOBAL CONFIGURATION
# =============================================================================

# Environment (development | staging | production)
NODE_ENV=development

# =============================================================================
# BACKEND API (Express.js)
# =============================================================================

# Server
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/codecourt
# Production example: mongodb+srv://user:pass@cluster.mongodb.net/codecourt?retryWrites=true&w=majority

# Redis
REDIS_URL=redis://localhost:6379
# Production example: redis://redis-service:6379

# JWT Authentication
ACCESS_TOKEN_SECRET=changeme_access_secret_min_32_chars
REFRESH_TOKEN_SECRET=changeme_refresh_secret_min_32_chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# AWS S3 (Test Case Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=codecourt-test-cases

# Service URLs
AI_SERVICE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# =============================================================================
# AI SERVICE (FastAPI)
# =============================================================================

# Groq API (LLM for hint generation)
GROQ_API_KEY=your_groq_api_key_here

# Express API URL (for agent tools)
EXPRESS_API_URL=http://localhost:5000

# AI Service Port
AI_SERVICE_PORT=8000

# =============================================================================
# FRONTEND (Next.js)
# =============================================================================

# API Endpoints (must be prefixed with NEXT_PUBLIC_ for client-side access)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_AI_URL=http://localhost:8000
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# =============================================================================
# DOCKER COMPOSE
# =============================================================================

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme_mongo_password

# Redis (no auth in development, use password in production)
REDIS_PASSWORD=

# =============================================================================
# KUBERNETES / PRODUCTION
# =============================================================================

# Oracle Cloud Kubernetes (OKE)
OKE_CLUSTER_ID=
OKE_COMPARTMENT_ID=

# MongoDB Atlas
ATLAS_PROJECT_ID=
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=

# GitHub Container Registry
GHCR_TOKEN=

# =============================================================================
# TERRAFORM
# =============================================================================

# AWS
TF_VAR_aws_access_key=
TF_VAR_aws_secret_key=
TF_VAR_aws_region=us-east-1

# MongoDB Atlas
TF_VAR_atlas_public_key=
TF_VAR_atlas_private_key=
TF_VAR_atlas_project_id=

# Oracle Cloud
TF_VAR_oci_tenancy_ocid=
TF_VAR_oci_user_ocid=
TF_VAR_oci_fingerprint=
TF_VAR_oci_private_key_path=
TF_VAR_oci_region=us-ashburn-1

# =============================================================================
# DEVELOPMENT / TESTING
# =============================================================================

# Judge Container Settings
JUDGE_TIMEOUT_GRACE_PERIOD_MS=2000
JUDGE_MAX_CONCURRENT=5

# BullMQ Worker Settings
BULLMQ_CONCURRENCY=5

# Cron Settings
CONTEST_CRON_INTERVAL=30000

# Logging
LOG_LEVEL=info
# Options: error | warn | info | debug

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. NEVER commit the actual .env file to version control
# 2. Generate strong secrets for JWT tokens: openssl rand -base64 32
# 3. MongoDB Atlas connection string format:
#    mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
# 4. Groq API key: Sign up at https://console.groq.com
# 5. AWS credentials: Create IAM user with S3 full access
# 6. In production, use Kubernetes secrets instead of .env files
# 7. Each service directory (backend/, ai-service/, frontend/) has its own
#    .env.example with service-specific variables
#
