{
  "name": "codecourt-backend",
  "version": "1.0.0",
  "description": "CodeCourt MVP - Express.js Backend API",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "jest --coverage --testPathIgnorePatterns=integration.test.js",
    "test:unit": "jest --testPathIgnorePatterns=integration.test.js",
    "test:integration": "jest --testPathPatterns=integration.test.js --runInBand",
    "test:all": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "keywords": [
    "competitive-programming",
    "judge",
    "express",
    "mongodb",
    "redis",
    "bullmq"
  ],
  "author": "CodeCourt Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@kubernetes/client-node": "^1.4.0",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
