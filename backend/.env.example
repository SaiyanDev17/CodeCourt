# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/codecourt

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (change these in production!)
ACCESS_TOKEN_SECRET=changeme_access_secret_min_32_chars
REFRESH_TOKEN_SECRET=changeme_refresh_secret_min_32_chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=codecourt-test-cases

# AI Service
AI_SERVICE_URL=http://localhost:8000

# Frontend
FRONTEND_URL=http://localhost:3000

# Kubernetes (for production)
K8S_NAMESPACE=codecourt
